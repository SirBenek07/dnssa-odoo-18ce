<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_project_task_selection" model="ir.ui.view">
        <field name="name">account.move.form.project.task.selection</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <field
                    name="project_id"
                    groups="project.group_project_user"
                    invisible="move_type == 'entry'"
                    readonly="state != 'draft'"
                    domain="['|', ('company_id', '=', False), ('company_id', '=', company_id)]"
                />
            </xpath>
            <xpath expr="//label[@name='invoice_vendor_bill_id_label']" position="replace">
                <label
                    for="concepto"
                    string="Concepto"
                    invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                />
            </xpath>
            <xpath expr="//field[@name='invoice_vendor_bill_id']" position="replace">
                <field
                    name="concepto"
                    nolabel="1"
                    invisible="move_type not in ('in_invoice', 'in_refund', 'in_receipt')"
                    readonly="state != 'draft'"
                />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='name']" position="after">
                <field
                    name="project_id"
                    optional="show"
                    domain="['|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                    readonly="parent.state != 'draft'"
                />
                <field
                    name="task_id"
                    optional="show"
                    domain="[('parent_id', '=', False), ('is_closed', '=', False), ('active', '=', True), ('display_in_project', '=', True), ('is_template_project', '=', False), ('is_task_template', '=', False), ('project_id', '=?', project_id), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                    readonly="parent.state != 'draft'"
                />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='analytic_distribution']" position="after">
                <field
                    name="project_id"
                    domain="['|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                    readonly="parent.state != 'draft'"
                />
                <field
                    name="task_id"
                    domain="[('parent_id', '=', False), ('is_closed', '=', False), ('active', '=', True), ('display_in_project', '=', True), ('is_template_project', '=', False), ('is_task_template', '=', False), ('project_id', '=?', project_id), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                    readonly="parent.state != 'draft'"
                />
            </xpath>
        </field>
    </record>

    <record id="account_invoice_list_concepto" model="ir.ui.view">
        <field name="name">account.invoice.list.concepto</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='invoice_partner_display_name'][1]" position="after">
                <field
                    name="concepto"
                    optional="show"
                    column_invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund', 'in_receipt')"
                />
            </xpath>
        </field>
    </record>
</odoo>
