    <record id="product_form_view_purchase_invoice_button" model="ir.ui.view">
        <field name="name">product.product.purchase.invoice.button</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="purchase.product_normal_form_view_inherit_purchase"/>
