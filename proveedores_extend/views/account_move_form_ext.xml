<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_vendor_timbrado" model="ir.ui.view">
        <field name="name">account.move.form.vendor.timbrado</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']/field[@name='payment_reference']" position="after">
                <field
                    name="partner_timbrado_id"
                    string="Timbrado"
                    invisible="move_type != 'in_invoice'"
                    required="move_type == 'in_invoice' and state == 'posted'"
                    domain="[('partner_id', '=', partner_id)]"
                    context="{
                        'default_partner_id': partner_id,
                        'default_is_electronic': l10n_py_document_type == 'electronic',
                        'invoice_is_electronic': l10n_py_document_type == 'electronic',
                    }"
                    options="{'no_quick_create': True}"
                />
                <field name="timbrado" invisible="1" force_save="1"/>
                <field
                    name="validez_timbrado"
                    invisible="move_type != 'in_invoice' or l10n_py_document_type == 'electronic'"
                    required="move_type == 'in_invoice' and state == 'posted' and l10n_py_document_type != 'electronic'"
                    force_save="1"
                />
            </xpath>
        </field>
    </record>
</odoo>
