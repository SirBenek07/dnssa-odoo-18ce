<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_partner_timbrado_form" model="ir.ui.view">
        <field name="name">res.partner.timbrado.form</field>
        <field name="model">res.partner.timbrado</field>
        <field name="arch" type="xml">
            <form string="Timbrado">
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="name"/>
                        <field
                            name="is_electronic"
                            readonly="context.get('invoice_is_electronic')"
                            force_save="1"
                        />
                        <field
                            name="validez_timbrado"
                            invisible="is_electronic or context.get('invoice_is_electronic')"
                            required="not is_electronic and not context.get('invoice_is_electronic')"
                        />
                        <field name="is_default"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_partner_form_timbrado" model="ir.ui.view">
        <field name="name">res.partner.form.timbrado</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page name="timbrados" string="Timbrados">
                    <field name="timbrado_ids" context="{'default_partner_id': id}">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="is_electronic"/>
                            <field
                                name="validez_timbrado"
                                invisible="is_electronic"
                                required="not is_electronic"
                            />
                            <field name="is_default"/>
                        </list>
                        <form string="Timbrado">
                            <sheet>
                                <group>
                                    <field name="partner_id" invisible="1"/>
                                    <field name="name"/>
                                    <field name="is_electronic"/>
                                    <field
                                        name="validez_timbrado"
                                        invisible="is_electronic"
                                        required="not is_electronic"
                                    />
                                    <field name="is_default"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
