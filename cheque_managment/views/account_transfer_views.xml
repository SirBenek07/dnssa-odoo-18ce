<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_transfer_performed_list" model="ir.ui.view">
        <field name="name">account.transfer.performed.list</field>
        <field name="model">account.transfer.performed</field>
        <field name="arch" type="xml">
            <list
                string="Transferencias realizadas"
                decoration-info="state == 'draft'"
                decoration-success="state == 'paid'"
                decoration-danger="state in ('canceled', 'rejected')"
            >
                <field name="date"/>
                <field name="transfer_number"/>
                <field name="partner_id"/>
                <field name="amount"/>
                <field name="journal_id"/>
                <field name="memo" optional="show"/>
                <field name="payment_id" optional="show"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'paid'"
                    decoration-warning="state == 'in_process'"
                    decoration-danger="state in ('canceled', 'rejected')"/>
            </list>
        </field>
    </record>

    <record id="view_account_transfer_performed_search" model="ir.ui.view">
        <field name="name">account.transfer.performed.search</field>
        <field name="model">account.transfer.performed</field>
        <field name="arch" type="xml">
            <search string="Buscar transferencias">
                <field name="transfer_number"/>
                <field name="partner_id"/>
                <field name="journal_id"/>
                <field name="date"/>
                <filter name="filter_in_process" string="En proceso" domain="[('state', '=', 'in_process')]"/>
                <filter name="filter_paid" string="Pagadas" domain="[('state', '=', 'paid')]"/>
                <filter name="filter_cancelled" string="Canceladas" domain="[('state', 'in', ('canceled', 'rejected'))]"/>
                <separator/>
                <filter name="group_by_journal" string="Banco" context="{'group_by': 'journal_id'}"/>
                <filter name="group_by_partner" string="Beneficiario" context="{'group_by': 'partner_id'}"/>
                <filter name="group_by_state" string="Estado" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_account_transfer_performed_form" model="ir.ui.view">
        <field name="name">account.transfer.performed.form</field>
        <field name="model">account.transfer.performed</field>
        <field name="arch" type="xml">
            <form string="Transferencia realizada">
                <sheet>
                    <group>
                        <group>
                            <field name="transfer_number"/>
                            <field name="date"/>
                            <field name="journal_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="state"/>
                            <field name="payment_method_line_id"/>
                            <field name="payment_id"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="memo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_account_transfer_performed" model="ir.actions.act_window">
        <field name="name">Transferencias realizadas</field>
        <field name="res_model">account.transfer.performed</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_account_transfer_performed_search"/>
    </record>

    <record id="view_account_transfer_journal_kanban" model="ir.ui.view">
        <field name="name">account.transfer.journal.kanban</field>
        <field name="model">account.journal</field>
        <field name="arch" type="xml">
            <kanban create="false" can_open="0" class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="bank_account_id"/>
                <field name="currency_id"/>
                <field name="transfer_count"/>
                <templates>
                    <t t-name="card">
                        <a type="object" name="action_open_transfers" class="d-block text-reset text-decoration-none">
                            <div class="row g-0">
                                <div class="col-8">
                                    <field class="fw-bolder" name="name"/>
                                    <div class="text-muted">
                                        <field name="bank_account_id"/>
                                    </div>
                                </div>
                                <div class="col-4 text-end">
                                    <span class="badge rounded-pill text-bg-primary">
                                        <field name="transfer_count"/>
                                    </span>
                                </div>
                                <div class="col-6 mt-2 text-muted">
                                    <field name="code"/>
                                </div>
                                <div class="col-6 mt-2 text-end text-muted">
                                    <field name="currency_id"/>
                                </div>
                            </div>
                        </a>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_account_transfer_journal" model="ir.actions.act_window">
        <field name="name">Transferencias realizadas</field>
        <field name="res_model">account.journal</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_account_transfer_journal_kanban"/>
        <field name="domain">[('type', '=', 'bank')]</field>
        <field name="context">{'default_type': 'bank'}</field>
    </record>

    <menuitem
        id="menu_account_transfer_management"
        name="Transferencias realizadas"
        parent="account.menu_finance_entries"
        action="action_account_transfer_journal"
        groups="account.group_account_readonly"
        sequence="41"
    />
</odoo>
