<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_form_impuesto_inmobiliario" model="ir.ui.view">
        <field name="name">account.tax.form.impuesto.inmobiliario</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='advanced_booleans']" position="inside">
                <field name="is_impuesto_inmobiliario"/>
            </xpath>
        </field>
    </record>
</odoo>
