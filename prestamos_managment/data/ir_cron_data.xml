<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_prestamos_reclassify_short_term" model="ir.cron">
            <field name="name">Prestamos: reclasificar corto plazo</field>
            <field name="model_id" ref="model_prestamos_loan"/>
            <field name="state">code</field>
            <field name="code">model._cron_reclassify_short_term_lines()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=3, minute=0, second=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
