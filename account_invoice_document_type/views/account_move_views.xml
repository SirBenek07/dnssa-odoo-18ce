<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_move_form_document_type" model="ir.ui.view">
        <field name="name">account.move.form.document.type</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']/field[@name='payment_reference']" position="after">
                <field name="l10n_py_document_type" invisible="move_type == 'entry'"/>
                <field name="l10n_py_cdc" invisible="move_type == 'entry' or l10n_py_document_type != 'electronic'"/>
            </xpath>
        </field>
    </record>
</odoo>
