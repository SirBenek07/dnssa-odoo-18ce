<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_flujo_caja_wizard_form" model="ir.ui.view">
        <field name="name">flujo.caja.wizard.form</field>
        <field name="model">flujo.caja.wizard</field>
        <field name="arch" type="xml">
            <form string="Flujo de Caja">
                <group>
                    <field
                        name="company_id"
                        groups="base.group_multi_company"
                        options="{'no_create': True}"
                    />
                    <field
                        name="date_range_id"
                        domain="['|', ('company_id', '=', company_id), ('company_id', '=', False)]"
                        options="{'no_create': True}"
                    />
                    <field name="date_from" />
                    <field name="date_to" />
                    <field name="show_details" />
                    <field name="include_zero_lines" />
                </group>
                <footer>
                    <button
                        name="action_print_pdf"
                        type="object"
                        string="Imprimir PDF"
                        class="btn-primary"
                    />
                    <button string="Cancelar" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_flujo_caja_wizard" model="ir.actions.act_window">
        <field name="name">Flujo de Caja</field>
        <field name="res_model">flujo.caja.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_flujo_caja_wizard_form" />
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_flujo_caja_wizard"
        name="Flujo de Caja"
        parent="menu_reportes_financieros_root"
        action="action_flujo_caja_wizard"
        groups="account.group_account_user"
        sequence="20"
    />
</odoo>
